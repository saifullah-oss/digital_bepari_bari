rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===============================================================
    // Assumed Data Model
    // ===============================================================
    //
    // Collection: members
    // Document ID: {uid}
    // Fields:
    //   - name: string (required, 1-200 chars)
    //   - fatherName: string (optional)
    //   - dob: string (optional, format: date)
    //   - phone: string (required, 8-20 chars)
    //   - status: string (required, enum: ['pending', 'approved'])
    //   - role: string (required, enum: ['admin', 'member'])
    //   - uid: string (required, must match auth.uid)
    //   - createdAt: timestamp (required)
    //
    // Collection: events
    // Fields:
    //   - title: string (required, 1-200 chars)
    //   - description: string (required, <2000 chars)
    //   - date: string (required, format: date)
    //   - authorUid: string (required, must match auth.uid)
    //   - status: string (required, enum: ['pending', 'approved'])
    //
    // Collection: products
    // Fields:
    //   - name: string (required, 1-200 chars)
    //   - price: number (required, >=0)
    //   - sellerUid: string (required, must match auth.uid)
    //
    // ===============================================================

    // ===============================================================
    // Helper Functions
    // ===============================================================
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isAuthenticated() && (
        (exists(/databases/$(database)/documents/members/$(request.auth.uid)) && 
         get(/databases/$(database)/documents/members/$(request.auth.uid)).data.role == 'admin') || 
        (request.auth.token.email == "saifullahsojib998@gmail.com" && request.auth.token.email_verified == true)
      );
    }
    
    function isApproved() {
      return isAuthenticated() && 
             exists(/databases/$(database)/documents/members/$(request.auth.uid)) && 
             get(/databases/$(database)/documents/members/$(request.auth.uid)).data.status == 'approved';
    }

    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }

    function hasRequiredFields(fields) {
      return request.resource.data.keys().hasAll(fields);
    }

    function hasOnlyAllowedFields(fields) {
      return request.resource.data.keys().hasOnly(fields);
    }

    // Domain Validators
    function isValidMember(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.phone is string && data.phone.size() >= 8 && data.phone.size() <= 20 &&
             data.status in ['pending', 'approved'] &&
             data.role in ['admin', 'member'] &&
             data.uid is string && data.uid == request.auth.uid;
    }

    function isValidEvent(data) {
      return data.title is string && data.title.size() > 0 && data.title.size() < 200 &&
             data.description is string && data.description.size() < 2000 &&
             data.status in ['pending', 'approved'] &&
             data.authorUid is string && data.authorUid == request.auth.uid;
    }

    function isValidProduct(data) {
      return data.name is string && data.name.size() > 0 && data.name.size() < 200 &&
             data.price is number && data.price >= 0 &&
             data.sellerUid is string && data.sellerUid == request.auth.uid;
    }

    // ===============================================================
    // Rules
    // ===============================================================

    // Test connection rule
    match /test/connection {
      allow read: if true;
    }

    match /members/{memberId} {
      // Allow public read for troubleshooting
      allow read: if true;
      
      // Allow a user to create their own profile
      // If they are the bootstrap admin, they can set their role to 'admin'
      allow create: if isAuthenticated() && isOwner(memberId) && isValidMember(request.resource.data) && (
        request.resource.data.role == 'member' || isAdmin()
      );
      
      // Allow a user to update their own profile (but not their role or status unless admin)
      allow update: if isAuthenticated() && (
        (isOwner(memberId) && isValidMember(request.resource.data) && 
         request.resource.data.role == resource.data.role && 
         request.resource.data.status == resource.data.status) || 
        isAdmin()
      );
      
      // Only admins can delete members
      allow delete: if isAdmin();
    }

    match /events/{eventId} {
      allow read: if isAuthenticated();
      allow create: if isApproved() && isValidEvent(request.resource.data);
      allow update: if isAdmin() || (isApproved() && resource.data.authorUid == request.auth.uid && isValidEvent(request.resource.data));
      allow delete: if isAdmin() || (isApproved() && resource.data.authorUid == request.auth.uid);
    }

    match /products/{productId} {
      allow read: if isAuthenticated();
      allow create: if isApproved() && isValidProduct(request.resource.data);
      allow update: if isAdmin() || (isApproved() && resource.data.sellerUid == request.auth.uid && isValidProduct(request.resource.data));
      allow delete: if isAdmin() || (isApproved() && resource.data.sellerUid == request.auth.uid);
    }

    match /funds/{fundId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }

    match /sos/{sosId} {
      allow read: if isApproved();
      allow create: if isAuthenticated() && request.resource.data.uid == request.auth.uid;
      allow delete: if isAdmin() || (isAuthenticated() && resource.data.uid == request.auth.uid);
    }

    match /blood_donors/{donorId} {
      allow read: if isAuthenticated();
      allow create: if isApproved() && request.resource.data.uid == request.auth.uid;
      allow update: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid);
      allow delete: if isAdmin() || (isApproved() && resource.data.uid == request.auth.uid);
    }

    match /medicines/{medicineId} {
      allow read: if isAuthenticated();
      allow create: if isApproved() && request.resource.data.donorUid == request.auth.uid;
      allow update: if isAdmin() || (isApproved() && resource.data.donorUid == request.auth.uid);
      allow delete: if isAdmin() || (isApproved() && resource.data.donorUid == request.auth.uid);
    }

    // Default allow for troubleshooting
    match /{allPaths=**} {
      allow read, write: if true;
    }
  }
}
